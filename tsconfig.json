{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "./*.d.ts",
    "./src/*.ts",
    "./tests/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
